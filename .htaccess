# ============================================================
# .htaccess - Reglas Apache para el Ecommerce Pedagogico
# Version corregida - Permite peticiones AJAX a api/
# ============================================================

# Prevenir listado de directorios
Options -Indexes

# Bloquear acceso directo a includes/ (solo desde PHP)
<FilesMatch "^includes/.*\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquear acceso a archivos sensibles por extension
<FilesMatch "\.(sql|md|env|log|lock|bak|old)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquear archivos de configuracion de proyecto
<FilesMatch "^(composer\.json|composer\.lock|package\.json|package-lock\.json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquear acceso a archivos ocultos
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# api/ NO esta bloqueado - el frontend necesita acceso AJAX

# Forzar UTF-8
AddDefaultCharset UTF-8
